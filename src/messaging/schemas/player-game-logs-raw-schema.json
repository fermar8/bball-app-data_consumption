{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Player Game Logs Raw Payload Schema",
  "description": "Schema for raw player_game_logs documents consumed from S3",
  "type": "object",
  "required": [
    "source",
    "endpoint",
    "fetched_at_utc",
    "aws_account_id",
    "schema_version",
    "ingestion_id",
    "params",
    "payload"
  ],
  "properties": {
    "source": {
      "type": "string",
      "const": "nba_api"
    },
    "endpoint": {
      "type": "string",
      "const": "player_game_logs"
    },
    "fetched_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "aws_account_id": {
      "type": "string",
      "pattern": "^[0-9]{12}$"
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "ingestion_id": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": "object",
      "required": ["season", "date_from", "date_to"],
      "properties": {
        "season": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}$"
        },
        "date_from": {
          "type": "string",
          "pattern": "^[0-9]{2}/[0-9]{2}/[0-9]{4}$"
        },
        "date_to": {
          "type": "string",
          "pattern": "^[0-9]{2}/[0-9]{2}/[0-9]{4}$"
        }
      },
      "additionalProperties": true
    },
    "payload": {
      "type": "object",
      "required": ["resource", "parameters", "resultSets"],
      "properties": {
        "resource": {
          "type": "string",
          "const": "gamelogs"
        },
        "parameters": {
          "type": "object",
          "required": [
            "MeasureType",
            "PerMode",
            "LeagueID",
            "SeasonYear",
            "SeasonType",
            "PORound",
            "TeamID",
            "PlayerID",
            "Outcome",
            "Location",
            "Month",
            "SeasonSegment",
            "DateFrom",
            "DateTo",
            "OppTeamID",
            "VsConference",
            "VsDivision",
            "GameSegment",
            "Period",
            "ShotClockRange",
            "LastNGames",
            "ISTRound"
          ],
          "properties": {
            "MeasureType": { "type": "string" },
            "PerMode": { "type": "string" },
            "LeagueID": { "type": "string" },
            "SeasonYear": {
              "type": "string",
              "pattern": "^[0-9]{4}-[0-9]{2}$"
            },
            "SeasonType": { "type": ["string", "null"] },
            "PORound": { "type": ["integer", "null"] },
            "TeamID": { "type": "integer" },
            "PlayerID": { "type": "integer" },
            "Outcome": { "type": ["string", "null"] },
            "Location": { "type": ["string", "null"] },
            "Month": { "type": ["integer", "null"] },
            "SeasonSegment": { "type": ["string", "null"] },
            "DateFrom": {
              "type": "string",
              "pattern": "^[0-9]{2}/[0-9]{2}/[0-9]{4}$"
            },
            "DateTo": {
              "type": "string",
              "pattern": "^[0-9]{2}/[0-9]{2}/[0-9]{4}$"
            },
            "OppTeamID": { "type": ["integer", "null"] },
            "VsConference": { "type": ["string", "null"] },
            "VsDivision": { "type": ["string", "null"] },
            "GameSegment": { "type": ["string", "null"] },
            "Period": { "type": ["integer", "null"] },
            "ShotClockRange": { "type": ["string", "null"] },
            "LastNGames": { "type": ["integer", "null"] },
            "ISTRound": { "type": ["integer", "null"] }
          },
          "additionalProperties": false
        },
        "resultSets": {
          "type": "array",
          "minItems": 1,
          "contains": {
            "type": "object",
            "required": ["name", "headers", "rowSet"],
            "properties": {
              "name": {
                "const": "PlayerGameLogs"
              },
              "headers": {
                "type": "array",
                "minItems": 40,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "SEASON_YEAR",
                    "PLAYER_ID",
                    "PLAYER_NAME",
                    "NICKNAME",
                    "TEAM_ID",
                    "TEAM_ABBREVIATION",
                    "TEAM_NAME",
                    "GAME_ID",
                    "GAME_DATE",
                    "MATCHUP",
                    "WL",
                    "MIN",
                    "FGM",
                    "FGA",
                    "FG_PCT",
                    "FG3M",
                    "FG3A",
                    "FG3_PCT",
                    "FTM",
                    "FTA",
                    "FT_PCT",
                    "OREB",
                    "DREB",
                    "REB",
                    "AST",
                    "TOV",
                    "STL",
                    "BLK",
                    "BLKA",
                    "PF",
                    "PFD",
                    "PTS",
                    "PLUS_MINUS",
                    "NBA_FANTASY_PTS",
                    "DD2",
                    "TD3",
                    "WNBA_FANTASY_PTS",
                    "GP_RANK",
                    "W_RANK",
                    "L_RANK",
                    "W_PCT_RANK",
                    "MIN_RANK",
                    "FGM_RANK",
                    "FGA_RANK",
                    "FG_PCT_RANK",
                    "FG3M_RANK",
                    "FG3A_RANK",
                    "FG3_PCT_RANK",
                    "FTM_RANK",
                    "FTA_RANK",
                    "FT_PCT_RANK",
                    "OREB_RANK",
                    "DREB_RANK",
                    "REB_RANK",
                    "AST_RANK",
                    "TOV_RANK",
                    "STL_RANK",
                    "BLK_RANK",
                    "BLKA_RANK",
                    "PF_RANK",
                    "PFD_RANK",
                    "PTS_RANK",
                    "PLUS_MINUS_RANK",
                    "NBA_FANTASY_PTS_RANK",
                    "DD2_RANK",
                    "TD3_RANK",
                    "WNBA_FANTASY_PTS_RANK",
                    "AVAILABLE_FLAG",
                    "MIN_SEC",
                    "TEAM_COUNT"
                  ]
                },
                "allOf": [
                  { "contains": { "const": "PLAYER_ID" } },
                  { "contains": { "const": "GAME_ID" } },
                  { "contains": { "const": "GAME_DATE" } },
                  { "contains": { "const": "PTS" } },
                  { "contains": { "const": "AVAILABLE_FLAG" } },
                  { "contains": { "const": "MIN_SEC" } },
                  { "contains": { "const": "TEAM_COUNT" } }
                ]
              },
              "rowSet": {
                "type": "array",
                "items": {
                  "type": "array",
                  "minItems": 40,
                  "items": [
                    { "type": "string" },
                    { "type": "integer" },
                    { "type": "string" },
                    { "type": "string" },
                    { "type": "integer" },
                    { "type": "string" },
                    { "type": "string" },
                    { "type": "string" },
                    { "type": "string" },
                    { "type": "string" },
                    { "type": "string" },
                    { "type": ["number", "string"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["number", "null"] },
                    { "type": ["number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": ["number", "null"] },
                    { "type": ["integer", "number", "null"] },
                    { "type": "string" },
                    { "type": ["integer", "number", "null"] }
                  ],
                  "additionalItems": {
                    "type": ["integer", "number", "null"]
                  }
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
