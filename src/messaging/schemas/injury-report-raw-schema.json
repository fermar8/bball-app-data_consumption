{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Injury Report Raw Payload Schema",
  "description": "Schema for raw injury_report documents consumed from S3",
  "type": "object",
  "required": [
    "source",
    "endpoint",
    "fetched_at_utc",
    "aws_account_id",
    "schema_version",
    "ingestion_id",
    "params",
    "payload"
  ],
  "properties": {
    "source": {
      "type": "string",
      "minLength": 1
    },
    "endpoint": {
      "type": "string",
      "const": "injury_report"
    },
    "fetched_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "aws_account_id": {
      "type": "string",
      "pattern": "^[0-9]{12}$"
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "ingestion_id": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": "object"
    },
    "payload": {
      "type": "object",
      "required": ["source", "count", "injuries"],
      "properties": {
        "source": { "type": "string" },
        "raw_entries_count": { "type": "integer", "minimum": 0 },
        "count": { "type": "integer", "minimum": 0 },
        "updated_at": { "type": ["string", "null"] },
        "injuries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "player_id",
              "player_name",
              "team_abbr",
              "status",
              "availability",
              "reason_type",
              "reason",
              "report_date"
            ],
            "properties": {
              "player_id": { "type": ["integer", "null"] },
              "player_name": { "type": "string" },
              "team_abbr": { "type": "string" },
              "status": { "type": "string" },
              "availability": { "type": "string" },
              "reason_type": { "type": "string" },
              "reason": { "type": "string" },
              "report_date": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
